
// asQspi.sv
`timescale 1ns/1ps

import as_pack::*;

module as_qspi ( input  logic        rst_i,
                 input  logic        clk_i,
                 // BPI <-> kernel side
                 // ... ctrl register
                 input logic         start_i,        // Puls vom Top (1 Zyklus)
                 input qspi_ctrl_t   ctrl_reg_i,     // Control register elements
                 input logic [7:0]   cmd_reg_i,      // NOR-flash opcode
                 input logic [31:0]  addr_reg_i,     // NOR-flash address
                 input logic [15:0]  len_reg_i,      // SPI transfer length
                 input logic [5:0]   dummy_reg_i,    // SPI dummy cycles
                 input logic [7:0]   clkdiv_reg_i,   // SCK = f_clk / (2*(CLKDIV+1))
                 input logic [31:0]  timeout_reg_i,  // Timeout level
                 output logic        stat_busy_o,    // FSM active, level, to status register
                 output logic        stat_done_o,    // FSM in DONE, pulse, to status register
                 output logic        stat_error_o,   // Error latched, level, to status register
                 output logic        stat_timeout_o, // Timeput, level, to status register
                 input  logic        tx_empty_i,     // TX-FIFO empty
                 input  logic        rx_full_i,      // RX-FIFO full
                 output logic        tx_rd_o,        // Read strobe to TX-FIFO
                 output logic        rx_wr_o,        // Write strobe to RX-FIFO
                 input  logic [63:0] tx_data_i,      // From TX-FIFO
                 output logic [63:0] rx_data_o,      // To RX-FIFO
                 // Chip SPI signals
                 output logic        sck_o,          // SPI clock
                 output logic        cs_o,           // SPI chip select
                 inout  tri [3:0]    data_io         // SPI data
               );
  // FSM
  // ===========================================================================
  // FSM state encoding
  // ===========================================================================
  typedef enum logic [2:0] {
    IDLE_ST = 3'd0,
    CMD_ST  = 3'd1,
    ADDR_ST = 3'd2,
    DUM_ST  = 3'd3,
    DAT_ST  = 3'd4,
    DONE_ST = 3'd5
  } statetype_t;

  statetype_t state_r, nextstate_s;

  // Hilfssignale: Bits pro SCK-Zyklus (1, 2 oder 4)
  logic [2:0]  bits_per_cyc_s;
  assign bits_per_cyc_s = ctrl_reg_i.quad ? 3'd4 : ctrl_reg_i.dual ? 3'd2 : 3'd1;
  // CMD phase: always 8 bits, so cycles = 8 / bits_per_cyc
  // Stored as max counter value (count from 0 to cmd_cyc_max_s inclusive)
  logic [2:0] cmd_cyc_max_s;
  always_comb
    case(bits_per_cyc_s)
      3'd4:    cmd_cyc_max_s = 3'd1;   // 8/4 = 2 cycles → 0..1
      3'd2:    cmd_cyc_max_s = 3'd3;   // 8/2 = 4 cycles → 0..3
      default: cmd_cyc_max_s = 3'd7;   // 8/1 = 8 cycles → 0..7
    endcase
  
  // ADDR phase: 24 or 32 bits, cycles = addr_bits / bits_per_cyc
  // addr_len=0 → 24 bit, addr_len=1 → 32 bit
  logic [4:0] addr_bits_s;        // 24 or 32
  logic [4:0] addr_cyc_max_s;     // max counter value (0-based)
  assign addr_bits_s    = ctrl_reg_i.addr_len ? 5'd32 : 5'd24;
  always_comb
    case (bits_per_cyc_s)
      3'd4:    addr_cyc_max_s = ctrl_reg_i.addr_len ? 5'd7  : 5'd5;  // 32/4-1, 24/4-1
      3'd2:    addr_cyc_max_s = ctrl_reg_i.addr_len ? 5'd15 : 5'd11; // 32/2-1, 24/2-1
      default: addr_cyc_max_s = ctrl_reg_i.addr_len ? 5'd31 : 5'd23; // 32/1-1, 24/1-1
    endcase

  // DATA phase: len_reg_i bytes = len_reg_i*8 bits total
  // cnt_dat_r counts *bits* (not bytes), max = len_reg_i*8 - 1
  // With 16-bit byte counter max bits = 65535*8 = 524280 → 20 bits needed
  logic [19:0] dat_bit_max_s;
  assign dat_bit_max_s = {len_reg_i, 3'b000} - 20'd1; // len*8 - 1
  
  // ===========================================================================
  // SCK generator
  // ===========================================================================
  // Toggle register: toggles when sck_cnt_r reaches clkdiv_reg_i
  // sck_en_s: SCK only runs during CMD / ADDR / DUM / DAT phases
  // sck_rise_s / sck_fall_s: single-cycle strobes at SCK edges

  logic       sck_en_s;
  logic [7:0] sck_cnt_r;
  logic       sck_r;
  logic       sck_rise_s;   // strobe: SCK rising  edge (0→1)
  logic       sck_fall_s;   // strobe: SCK falling edge (1→0)

  always_comb begin
    case (state_r)
      CMD_ST, ADDR_ST, DUM_ST, DAT_ST : sck_en_s = 1'b1;
      default                         : sck_en_s = 1'b0;
    endcase
  end

  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i) begin
      sck_cnt_r <= '0;
      sck_r     <= 1'b0;
    end else if (!sck_en_s) begin
      sck_cnt_r <= '0;
      sck_r     <= ctrl_reg_i.cpol;   // SCK idle level per CPOL
    end else begin
      if (sck_cnt_r >= clkdiv_reg_i) begin
        sck_cnt_r <= '0;
        sck_r     <= ~sck_r;
      end else begin
        sck_cnt_r <= sck_cnt_r + 8'd1;
      end
    end
  end

  assign sck_o = sck_r;
  
  // Edge detection: strobe one clk_i cycle before the SCK edge occurs
  // (i.e. when the counter is about to wrap and sck will toggle next cycle)
  assign sck_fall_s = sck_en_s && (sck_cnt_r == clkdiv_reg_i) &&  sck_r;
  assign sck_rise_s = sck_en_s && (sck_cnt_r == clkdiv_reg_i) && !sck_r;

  // For Mode 0 (CPOL=0, CPHA=0): drive on falling edge, sample on rising edge
  // For Mode 3 (CPOL=1, CPHA=1): drive on rising edge,  sample on falling edge
  logic sck_drive_s;   // strobe: time to put new bit on data_io
  logic sck_sample_s;  // strobe: time to sample data_io

  assign sck_drive_s  = ctrl_reg_i.cpol ? sck_rise_s  : sck_fall_s;
  assign sck_sample_s = ctrl_reg_i.cpol ? sck_fall_s  : sck_rise_s;

  // ===========================================================================
  // Phase counters
  // ===========================================================================

  logic [2:0]  cnt_cmd_r;    // CMD:   counts SCK cycles 0..cmd_cyc_max_s
  logic [4:0]  cnt_addr_r;   // ADDR:  counts SCK cycles 0..addr_cyc_max_s
  logic [5:0]  cnt_dummy_r;  // DUMMY: counts SCK cycles 0..dummy_reg_i-1
  logic [19:0] cnt_dat_r;    // DATA:  counts bits        0..dat_bit_max_s

  // --- CMD counter ---
  // Runs only in CMD_ST. Increments on sck_drive_s (= new bit driven each cycle).
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      cnt_cmd_r <= '0;
    else if (state_r != CMD_ST)
      cnt_cmd_r <= '0;
    else if (sck_drive_s)
      cnt_cmd_r <= (cnt_cmd_r >= cmd_cyc_max_s) ? '0 : cnt_cmd_r + 3'd1;
  end

  // --- ADDR counter ---
  // Runs only in ADDR_ST.
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      cnt_addr_r <= '0;
    else if (state_r != ADDR_ST)
      cnt_addr_r <= '0;
    else if (sck_drive_s)
      cnt_addr_r <= (cnt_addr_r >= addr_cyc_max_s) ? '0 : cnt_addr_r + 5'd1;
  end
  
  // --- DUMMY counter ---
  // Runs only in DUM_ST. Counts SCK rising edges (one per dummy cycle).
  // If dummy_reg_i == 0 the FSM skips DUM_ST immediately (see FSM transitions).
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      cnt_dummy_r <= '0;
    else if (state_r != DUM_ST)
      cnt_dummy_r <= '0;
    else if (sck_rise_s)
      cnt_dummy_r <= cnt_dummy_r + 6'd1;
  end

  // --- DATA counter ---
  // Runs only in DAT_ST. Counts bits (each sck_drive_s = 1/2/4 bits transferred).
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      cnt_dat_r <= '0;
    else if (state_r != DAT_ST)
      cnt_dat_r <= '0;
    else if (sck_drive_s)
      cnt_dat_r <= cnt_dat_r + {17'd0, bits_per_cyc_s};
  end

  // ===========================================================================
  // TX direction flag
  // ===========================================================================
  // Set at start_i when TX-FIFO contains data → write transfer.
  // Cleared on return to IDLE.

  logic tx_flag_r;
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      tx_flag_r <= 1'b0;
    else if (start_i && !tx_empty_i)
      tx_flag_r <= 1'b1;
    else if (state_r == IDLE_ST)
      tx_flag_r <= 1'b0;
  end

  // ===========================================================================
  // TX shift register
  // ===========================================================================
  // Loaded from tx_data_i at the start of DAT_ST.
  // Shifted left by 1/2/4 bits on each sck_drive_s.

  logic [63:0] tx_shift_r;
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      tx_shift_r <= '0;
    else if (state_r == CMD_ST && nextstate_s == DAT_ST)
      tx_shift_r <= tx_data_i;       // preload one cycle before DAT_ST
    else if (state_r == DAT_ST && tx_flag_r && sck_drive_s) begin
      case (bits_per_cyc_s)
        3'd4:    tx_shift_r <= {tx_shift_r[59:0], 4'b0000};
        3'd2:    tx_shift_r <= {tx_shift_r[61:0], 2'b00};
        default: tx_shift_r <= {tx_shift_r[62:0], 1'b0};
      endcase
    end
  end

  // ===========================================================================
  // RX shift register
  // ===========================================================================
  // Sampled on sck_sample_s during DAT_ST (read transfer only).
  // Every 8 bits a complete byte is available; rx_wr_o pulses to push to FIFO.

  logic [63:0] rx_shift_r;
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      rx_shift_r <= '0;
    else if (state_r == DAT_ST && !tx_flag_r && sck_sample_s) begin
      case (bits_per_cyc_s)
        3'd4:    rx_shift_r <= {rx_shift_r[59:0], data_io};
        3'd2:    rx_shift_r <= {rx_shift_r[61:0], data_io[1:0]};
        default: rx_shift_r <= {rx_shift_r[62:0], data_io[0]};
      endcase
    end
  end

  assign rx_data_o = rx_shift_r;

  // ===========================================================================
  // data_io tri-state driver
  // ===========================================================================

  logic [3:0] data_out_s;
  logic       data_oe_s;

  always_comb begin
    data_out_s = 4'b0000;
    data_oe_s  = 1'b0;

    case (state_r)
      // -----------------------------------------------------------------------
      // CMD phase: always Single-SPI, MSB first on io[0]
      // -----------------------------------------------------------------------
      CMD_ST : begin
        data_out_s = {3'b000, cmd_reg_i[3'd7 - cnt_cmd_r]};
        data_oe_s  = 1'b1;
      end

      // -----------------------------------------------------------------------
      // ADDR phase: Single / Dual / Quad, MSB first
      // addr_reg_i is right-aligned; we pick bits from the top of the
      // relevant field (24 or 32 bits).
      // -----------------------------------------------------------------------
      ADDR_ST : begin
        data_oe_s = 1'b1;
        case (bits_per_cyc_s)
          3'd4: begin
            // Nibble: pick 4 bits from MSB of addr field downward
            // addr_cyc_max_s - cnt_addr_r gives distance from MSB nibble
            automatic logic [4:0] nibble_idx;
            nibble_idx = addr_cyc_max_s - cnt_addr_r;  // 0 = MSB nibble
            data_out_s = addr_reg_i[{nibble_idx, 2'b11} -: 4];
          end
          3'd2: begin
            automatic logic [4:0] pair_idx;
            pair_idx   = addr_cyc_max_s - cnt_addr_r;
            data_out_s = {2'b00, addr_reg_i[{pair_idx, 1'b1} -: 2]};
          end
          default: begin
            // Single: pick one bit, MSB first
            // For 24-bit: top bit index = 23; for 32-bit: 31
            automatic logic [4:0] bit_idx;
            bit_idx    = addr_cyc_max_s - cnt_addr_r;
            data_out_s = {3'b000, addr_reg_i[bit_idx]};
          end
        endcase
      end

      // -----------------------------------------------------------------------
      // DUMMY phase: Hi-Z
      // -----------------------------------------------------------------------
      DUM_ST : begin
        data_out_s = 4'b0000;
        data_oe_s  = 1'b0;
      end

      // -----------------------------------------------------------------------
      // DATA phase
      // TX: drive from tx_shift_r MSBs
      // RX: Hi-Z (sampled into rx_shift_r above)
      // -----------------------------------------------------------------------
      DAT_ST : begin
        if (tx_flag_r) begin
          data_oe_s = 1'b1;
          case (bits_per_cyc_s)
            3'd4:    data_out_s = tx_shift_r[63:60];
            3'd2:    data_out_s = {2'b00, tx_shift_r[63:62]};
            default: data_out_s = {3'b000, tx_shift_r[63]};
          endcase
        end else begin
          data_out_s = 4'b0000;
          data_oe_s  = 1'b0;   // Hi-Z: let flash drive the bus
        end
      end

      default : begin
        data_out_s = 4'b0000;
        data_oe_s  = 1'b0;
      end
    endcase
  end

  assign data_io = data_oe_s ? data_out_s : 4'bzzzz;

  // ===========================================================================
  // FIFO strobes
  // ===========================================================================
  // tx_rd_o: pop next 64-bit word from TX-FIFO after every 8 bytes (64 bits)
  //          tx_shift_r is reloaded from tx_data_i at that point.
  // rx_wr_o: push completed 64-bit word into RX-FIFO after every 8 bytes.
  //
  // cnt_dat_r[5:0] counts bits within the current 64-bit FIFO word.
  // At bits 63→64 (i.e. when cnt_dat_r[5:0] wraps through 0) a full word
  // has been processed.

  logic byte_done_s;   // every 8 bits one byte is complete
  logic word_done_s;   // every 64 bits one FIFO word is complete

  // byte_done_s: true on the sck_drive_s (TX) / sck_sample_s (RX) cycle
  // where the bit counter crosses a byte boundary
  // We use the lower 3 bits of cnt_dat_r to detect byte completion.
  // After increment, bits [2:0] == 0 means 8 bits done.
  // We detect it one cycle later for simplicity (registered):
  always_comb begin
    byte_done_s = 1'b0;
    word_done_s = 1'b0;
    if (state_r == DAT_ST) begin
      // A byte is complete when the bit counter (after increment) is a
      // multiple of 8.  Since cnt_dat_r is updated on sck_drive_s /
      // sck_sample_s, we check the *current* value before the increment:
      // current bits[2:0] == (8 - bits_per_cyc_s) means next step completes a byte.
      case (bits_per_cyc_s)
        3'd4:    byte_done_s = sck_drive_s && (cnt_dat_r[2:0] == 3'd4);
        3'd2:    byte_done_s = sck_drive_s && (cnt_dat_r[2:0] == 3'd6);
        default: byte_done_s = sck_drive_s && (cnt_dat_r[2:0] == 3'd7);
      endcase
      // A 64-bit word is complete every 8 bytes
      word_done_s = byte_done_s && (cnt_dat_r[5:0] == 6'd56 ||
                                    cnt_dat_r[5:0] == 6'd0  );
      // Simpler: word done when lower 6 bits are about to complete 64 bits
      // Rewrite: word done when cnt_dat_r[5:0] + bits_per_cyc == 64
    end
  end

  // TX FIFO read: reload tx_shift_r after each 64-bit word consumed
  assign tx_rd_o = (state_r == DAT_ST) && tx_flag_r  &&
                   sck_drive_s          &&
                   (cnt_dat_r[5:0] == (6'd64 - {3'd0, bits_per_cyc_s}));

  // RX FIFO write: push rx_shift_r after each 64-bit word received
  assign rx_wr_o = (state_r == DAT_ST) && !tx_flag_r &&
                   sck_sample_s         &&
                   (cnt_dat_r[5:0] == (6'd64 - {3'd0, bits_per_cyc_s}));

  // Reload tx_shift_r when tx_rd_o fires (next word from FIFO)
  // This is handled in the tx_shift_r always_ff above (preload trigger
  // can be extended here if back-to-back FIFO words are needed):
  // TODO: extend for multi-word transfers > 8 bytes

  // ===========================================================================
  // CS output
  // ===========================================================================
  always_comb begin
    case (state_r)
      IDLE_ST : cs_o = 1'b0;
      DONE_ST : cs_o = 1'b0;
      default : cs_o = 1'b1;   // active during CMD/ADDR/DUM/DAT
    endcase
  end
  // Note: CS_HOLD (keep CS asserted between transactions) not yet implemented.

  // ===========================================================================
  // Error latch
  // ===========================================================================
  // Latched; cleared only by external reset or ICR write (done in Top).
  // stat_error_o is level; Top writes it into RIS on a rising edge.

  logic error_r;
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      error_r <= 1'b0;
    else if (state_r == DAT_ST && tx_flag_r  && tx_empty_i)
      error_r <= 1'b1;   // TX underflow: kernel needs data but FIFO is empty
    else if (state_r == DAT_ST && !tx_flag_r && rx_full_i)
      error_r <= 1'b1;   // RX overflow:  kernel has data but FIFO is full
  end

  assign stat_error_o = error_r;

  // ===========================================================================
  // Timeout counter
  // ===========================================================================
  // Counts down from timeout_reg_i while FSM is not IDLE.
  // Disabled when timeout_reg_i == 0.
  // Latched; cleared on return to IDLE_ST.

  logic [31:0] timeout_cnt_r;
  logic        timeout_r;

  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i) begin
      timeout_cnt_r <= '0;
      timeout_r     <= 1'b0;
    end else if (state_r == IDLE_ST) begin
      timeout_cnt_r <= timeout_reg_i;   // reload when idle
      timeout_r     <= 1'b0;
    end else if (timeout_reg_i != '0) begin
      if (timeout_cnt_r != '0)
        timeout_cnt_r <= timeout_cnt_r - 32'd1;
      else
        timeout_r <= 1'b1;
    end
  end

  assign stat_timeout_o = timeout_r;

  // ===========================================================================
  // FSM – Part 1: Next-state logic (combinatorial)
  // ===========================================================================
  always_comb begin
    nextstate_s = state_r;   // default: stay
    case (state_r)

      IDLE_ST : begin
        if (start_i)
          nextstate_s = CMD_ST;
      end

      CMD_ST : begin
        // Leave when last CMD bit has been driven
        if (sck_drive_s && cnt_cmd_r >= cmd_cyc_max_s)
          nextstate_s = ADDR_ST;
      end

      ADDR_ST : begin
        // Leave when last ADDR bit has been driven
        if (sck_drive_s && cnt_addr_r >= addr_cyc_max_s)
          nextstate_s = (dummy_reg_i == '0) ? DAT_ST : DUM_ST;
      end

      DUM_ST : begin
        // Leave after dummy_reg_i SCK cycles
        if (cnt_dummy_r >= dummy_reg_i)
          nextstate_s = DAT_ST;
      end

      DAT_ST : begin
        // Leave when all bits transferred (cnt_dat_r wraps past dat_bit_max_s)
        if (sck_drive_s && cnt_dat_r >= dat_bit_max_s)
          nextstate_s = DONE_ST;
      end

      DONE_ST : begin
        // One cycle to deassert CS, then back to IDLE
        nextstate_s = IDLE_ST;
      end

      default : nextstate_s = IDLE_ST;

    endcase
  end

  // ===========================================================================
  // FSM – Part 2: State register (sequential)
  // ===========================================================================
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      state_r <= IDLE_ST;
    else
      state_r <= nextstate_s;
  end

  // ===========================================================================
  // FSM – Part 3: Status outputs (registered / combinatorial)
  // ===========================================================================

  // stat_busy_o: level, combinatorial
  assign stat_busy_o = (state_r != IDLE_ST) && (state_r != DONE_ST);

  // stat_done_o: 1-cycle pulse when DONE_ST is entered
  always_ff @(posedge clk_i, posedge rst_i) begin
    if (rst_i)
      stat_done_o <= 1'b0;
    else
      stat_done_o <= (nextstate_s == DONE_ST) && (state_r != DONE_ST);
  end

  // stat_error_o   → see error_r above
  // stat_timeout_o → see timeout_r above


endmodule : as_qspi

