set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR riscv64)

set(RISCV_PREFIX /opt/riscv/bin/riscv64-unknown-linux-gnu)

set(CMAKE_C_COMPILER ${RISCV_PREFIX}-gcc)
set(CMAKE_ASM_COMPILER ${RISCV_PREFIX}-as)
set(CMAKE_OBJCOPY ${RISCV_PREFIX}-objcopy)
set(CMAKE_LINKER ${RISCV_PREFIX}-ld)

set(CMAKE_ASM_FLAGS "-march=rv64i -mlittle-endian -g")
#set(CMAKE_ASM_FLAGS "")
set(CMAKE_EXE_LINKER_FLAGS "-b elf64-littleriscv")
