Un mit OpenOcd?                                                                                                                                                                                                

● Zwei Dateien genügen

  rv_nopipeline.cfg — Interface + TAP-Deklaration

  # Amontec JTAGKey2: FT2232H, VID=0x0403 PID=0xCFF8
  adapter driver ftdi
  ftdi vid_pid 0x0403 0xcff8
  ftdi channel 0

  # FT2232H Pin-Belegung JTAGKey2:
  #   ADBUS0=TCK  ADBUS1=TDI  ADBUS2=TDO  ADBUS3=TMS
  #   ACBUS0=nTRST (aktiv-LOW, OE über ACBUS2)
  ftdi layout_init 0x0c08 0x0f1b
  ftdi layout_signal nTRST -data 0x0100 -noe 0x0400
  ftdi layout_signal nSRST -data 0x0200 -noe 0x0800

  adapter speed 1000

  # TAP: IR=8 Bit (as_pack.sv: ir_width=8)
  # Kein -expected-id: IR-Reset-Wert 0x96 → BYPASS, kein IDCODE sichtbar für OpenOCD
  jtag newtap rv_nopipeline tap -irlen 8

  ---
  load_imem.tcl — Bit-Umkehr + Lader
  
  Warum Bit-Umkehr? OpenOCD shiftet LSB-first; das Schieberegister (dr_cell.sv) speichert den ersten TDI-Bit am höchsten Index. Deshalb gilt: hardware_value = bitrev(openocd_value).

  ┌─────────────────┬────────────┬────────────────────────────────────┐
  │      Wert       │  Hardware  │          OpenOCD-Argument          │
  ├─────────────────┼────────────┼────────────────────────────────────┤
  │ I-MEM IR        │ 0x80       │ bitrev(0x80,8) = 0x01              │
  ├─────────────────┼────────────┼────────────────────────────────────┤
  │ IDCODE IR       │ 0x04       │ bitrev(0x04,8) = 0x20              │
  ├─────────────────┼────────────┼────────────────────────────────────┤
  │ BYPASS IR       │ 0xFF       │ 0xFF (symmetrisch)                 │
  ├─────────────────┼────────────┼────────────────────────────────────┤
  │ IDCODE Readback │ 0xdeadbeef │ bitrev(0xdeadbeef,32) = 0xF77DB57B │
  └─────────────────┴────────────┴────────────────────────────────────┘

  # load_imem.tcl — I-MEM Lader für RV_NoPipeline
  #
  # DR-Frame (48 Bit): {addr[14:0], data[31:0], WE=1}
  #   im_scan_length = 15 + 32 + 1 = 48  (as_pack.sv)
  #   Für OpenOCD: jedes Feld einzeln bit-umkehren.

  proc bitrev {val nbits} {
      set r 0
      for {set i 0} {$i < $nbits} {incr i} {
          set r   [expr {($r << 1) | ($val & 1)}]
          set val [expr {$val >> 1}]
      }
      return $r
  }

  # Sanity-Check: IDCODE lesen bevor geladen wird
  proc rv_check_tap {} {
      irscan rv_nopipeline.tap 0x20          ;# IR = 0x04 (IDCODE), bitrev → 0x20
      set got [drscan rv_nopipeline.tap 32 0x00000000]
      set exp "0xf77db57b"                   ;# bitrev(0xdeadbeef, 32)
      if {[string equal -nocase $got $exp]} {
          puts "TAP OK  (IDCODE = $got)"
          return 1
      }
      puts "WARNUNG: IDCODE erwartet $exp, gelesen $got — Verdrahtung prüfen!"
      return 0
  }

  proc parse_mem {path} {
      set result {}
      set waddr  0
      set fp [open $path r]
      while {[gets $fp line] >= 0} {
          set line [regsub {//.*} $line ""]
          set line [string trim $line]
          if {$line eq ""} continue
          if {[string match "@*" $line]} {
              set waddr [expr "0x[string range $line 1 end]"]
              continue
          }
          foreach tok [split $line " \t"] {
              if {$tok eq ""} continue
              lappend result [list $waddr [expr "0x$tok"]]
              incr waddr
          }
      }
      close $fp
      return $result
  }

  proc rv_load_imem {mem_file} {
      set words [parse_mem $mem_file]
      if {[llength $words] == 0} { error "Keine Daten in $mem_file" }

      rv_check_tap

      puts "Lade [llength $words] Wörter aus '$mem_file' ..."

      # IR = 0x80 laden (I-MEM-Scan-Chain) → OpenOCD: bitrev(0x80,8) = 0x01
      irscan rv_nopipeline.tap 0x01
      runtest 2

      set idx 0
      set n   [llength $words]
      foreach entry $words {
          set waddr     [lindex $entry 0]
          set data      [lindex $entry 1]
          set byte_addr [expr {$waddr * 4}]

          # DR-Frame für OpenOCD (LSB-first):
          #   V[0]  = addr[14]  →  im_datao_s[47]
          #   V[14] = addr[0]
          #   V[15] = data[31]  →  im_datao_s[32]
          #   V[46] = data[0]
          #   V[47] = WE = 1    →  im_datao_s[0]
          set ar [bitrev $byte_addr 15]
          set dr [bitrev $data      32]
          set frame [expr {(1 << 47) | ($dr << 15) | $ar}]

          # drscan führt automatisch: RTI → ShiftDR → UpdateDR → RTI
          # Der UpdateDR→RTI-Übergang liefert den TCK-Puls für im_upd_del_s
          drscan rv_nopipeline.tap 48 [format "0x%012llx" $frame]

          incr idx
          if {$idx % 64 == 0 || $idx == $n} {
              puts -nonewline "  $idx/$n\r"; flush stdout
          }
      }

      puts "\nFertig — $n Wörter in I-MEM geschrieben."

      irscan rv_nopipeline.tap 0xff    ;# zurück auf BYPASS
      runtest 2
  }

