  ---
  Extrahierte TAP-Parameter
  
  ┌───────────────────┬──────────────────────────────┬─────────────────────────────────────────────┐
  │     Parameter     │             Wert             │                   Quelle                    │
  ├───────────────────┼──────────────────────────────┼─────────────────────────────────────────────┤
  │ ir_width          │ 8 Bit                        │ ip_jtag/src/as_pack.sv Zeile 37             │
  ├───────────────────┼──────────────────────────────┼─────────────────────────────────────────────┤
  │ I-MEM IR-Code     │ 0x80 (= 128)                 │ ir_decode.sv Zeile 133                      │
  ├───────────────────┼──────────────────────────────┼─────────────────────────────────────────────┤
  │ DR-Breite         │ 48 Bit                       │ im_scan_length = 15 + 32 + 1                │
  ├───────────────────┼──────────────────────────────┼─────────────────────────────────────────────┤
  │ DR-Frame          │ {addr[14:0], data[31:0], WE} │ asTopMem.sv Zeilen 297–299                  │
  ├───────────────────┼──────────────────────────────┼─────────────────────────────────────────────┤
  │ Shift-Reihenfolge │ MSB zuerst                   │ dr_cell.sv: erster TDI-Bit → höchster Index │
  ├───────────────────┼──────────────────────────────┼─────────────────────────────────────────────┤
  │ TRST-Polarität    │ aktiv LOW (TRST#)            │ tap_fsm.sv Zeile 44: trst_s = ~trst_i       │
  └───────────────────┴──────────────────────────────┴─────────────────────────────────────────────┘

  TRST ist bereits korrekt — der Kommentar in tap_fsm.sv sagt explizit // active-low TRST# per IEEE 1149.1. Kein Inverter nötig, JTAGKey2 passt direkt.

  ---
  DR-Frame im Detail

  Bit 47 ─── Bit 33 │ Bit 32 ─── Bit 1 │ Bit 0
    addr[14:0]       │  data[31:0]       │  WE
    (15 Bit)         │  (32 Bit)         │  (1 Bit)

  Shift-Reihenfolge (TDI): addr[14] zuerst, WE=1 zuletzt.

  Wichtig: Der Write-Enable-Mechanismus in asTopMem.sv hat eine 1-Takt-Verzögerung (im_upd_del_s): Der eigentliche SRAM-Schreibvorgang passiert einen TCK-Takt nach Update-DR — genau beim Übergang Update-DR →
  RTI. Das Programm berücksichtigt das.

  ---
  Vollständiges Python-Programm

  #!/usr/bin/env python3
  """
  rv_load_imem.py  –  Lädt eine .mem-Datei in den RV_NoPipeline I-Mem via JTAG.
  Hardware : Amontec JTAGKey2  (FT2232H, Kanal A = MPSSE/JTAG)
  Target   : as_top_mem  (RWU_RV/RV_NoPipeline)

  TAP-Parameter (aus ip_jtag + as_pack.sv):
    ir_width   = 8 Bit,  IR_IMEM = 0x80 (= 128)
    DR-Frame   = 48 Bit: {addr[14:0], data[31:0], WE=1}, MSB zuerst
    TRST#      = aktiv-LOW (IEEE 1149.1, passt direkt zum JTAGKey2)

  Setup Ubuntu:
    sudo rmmod ftdi_sio
    pip3 install pyftdi
    # udev-Regel: ATTR{idVendor}=="0403", ATTR{idProduct}=="cff8", MODE="0666"
  """

  import sys
  from pyftdi.jtag import JtagController
  from pyftdi.bits import BitSequence

  # ── Hardware ──────────────────────────────────────────────────────────────────
  JTAGKEY2_URL = 'ftdi://0x0403:0xcff8/1'   # Kanal A (JTAG/MPSSE)
  TCK_FREQ_HZ  = 1_000_000                  # 1 MHz; auf 5–10 MHz erhöhbar wenn stabil

  # ── TAP-Konstanten (aus ip_jtag/src/ir_decode.sv und as_pack.sv) ─────────────
  IR_WIDTH   = 8
  IR_IMEM    = 0x80   # I-Mem-Scan-Chain-Instruktion
  IR_BYPASS  = 0xFF   # BYPASS
  DR_WIDTH   = 48     # im_scan_length = 15 + 32 + 1
  IMEM_DEPTH = 8192   # Wörter (imemdepth in as_pack.sv)


  def parse_mem(path: str) -> list[tuple[int, int]]:
      """
      Liest eine Verilog-$readmemh-Datei.
      @<hex>-Direktiven setzen die aktuelle Wortadresse.
      Gibt [(byte_addr, word), ...] zurück.
      """
      result, word_addr = [], 0
      with open(path) as f:
          for raw in f:
              line = raw.split('//')[0].strip()
              if not line:
                  continue
              if line.startswith('@'):
                  word_addr = int(line[1:], 16)   # Wortadresse aus Direktive
                  continue
              for tok in line.split():
                  result.append((word_addr * 4, int(tok, 16) & 0xFFFF_FFFF))
                  word_addr += 1
      return result


  def tap_reset(ctrl: JtagController):
      """TAP-Reset: 5 × TMS=1 (Test-Logic-Reset), dann TMS=0 (Run-Test-Idle)."""
      ctrl.reset()   # pyftdi sendet 5×TMS=1, dann TMS=0


  def shift_ir(ctrl: JtagController, ir_val: int):
      """
      Lädt IR: RTI → (1,1,0,0) → Shift-IR → 8 Bit MSB-first → Exit1-IR → (1,0) → RTI.
      TMS-Sequenz von RTI nach Shift-IR:
        TMS=1: RTI → Select-DR-Scan
        TMS=1: Select-DR-Scan → Select-IR-Scan
        TMS=0: Select-IR-Scan → Capture-IR
        TMS=0: Capture-IR → Shift-IR
      """
      ctrl.write_tms(BitSequence('1100', msb=False))
      ctrl.shift_register(BitSequence(ir_val, msb=True, length=IR_WIDTH), read=False)
      # shift_register beendet den letzten Bit mit TMS=1 → Exit1-IR
      # Exit1-IR → Update-IR (TMS=1), Update-IR → RTI (TMS=0)
      ctrl.write_tms(BitSequence('10', msb=False))


  def write_word(ctrl: JtagController, byte_addr: int, data: int):
      """
      Schreibt ein 32-Bit-Wort via I-Mem-Scan-Chain.
      DR-Frame: {byte_addr[14:0], data[31:0], WE=1} = 48 Bit, MSB zuerst.
      Der eigentliche SRAM-Write passiert beim Update-DR → RTI-Übergang
      (wegen im_upd_del_s in asTopMem.sv).
      TMS-Sequenz von RTI nach Shift-DR:
        TMS=1: RTI → Select-DR-Scan
        TMS=0: Select-DR-Scan → Capture-DR
        TMS=0: Capture-DR → Shift-DR
      """
      frame_val = (byte_addr << 33) | (data << 1) | 1
      ctrl.write_tms(BitSequence('100', msb=False))
      ctrl.shift_register(BitSequence(frame_val, msb=True, length=DR_WIDTH), read=False)
      # Exit1-DR → Update-DR (TMS=1) → RTI (TMS=0)
      # Beim posedge TCK des RTI-Übergangs: im_upd_del_s=1 → iMemWr_s=1 → Write ✓
      ctrl.write_tms(BitSequence('10', msb=False))


  def rv_load(mem_file: str):
      words = parse_mem(mem_file)
      if not words:
          sys.exit("FEHLER: Keine Daten in .mem-Datei gefunden.")

      max_addr = max(a for a, _ in words)
      if max_addr >= IMEM_DEPTH * 4:
          sys.exit(f"FEHLER: Adresse 0x{max_addr:04x} überschreitet I-Mem ({IMEM_DEPTH} Wörter).")

      print(f"Lade {len(words)} Wort/Wörter aus '{mem_file}' …")
      print(f"  Adressbereich: 0x0000 – 0x{max_addr:04x}")

      ctrl = JtagController(trst=False)
      ctrl.configure(JTAGKEY2_URL, frequency=TCK_FREQ_HZ)
      try:
          tap_reset(ctrl)            # TMS-Reset, TRST-Pin nicht nötig
          shift_ir(ctrl, IR_IMEM)    # IR = 0x80 → I-Mem-Scan-Chain aktiv

          for idx, (addr, data) in enumerate(words):
              write_word(ctrl, addr, data)
              if (idx + 1) % 64 == 0 or idx + 1 == len(words):
                  pct = (idx + 1) * 100 // len(words)
                  print(f"  [{pct:3d}%] {idx+1}/{len(words)} Wörter\r", end='', flush=True)

          print(f"\nFertig. {len(words)} Wort/Wörter erfolgreich in I-Mem geschrieben.")

          # TAP aufräumen: BYPASS laden und reset
          shift_ir(ctrl, IR_BYPASS)
          tap_reset(ctrl)

      finally:
          ctrl.close()


  if __name__ == '__main__':
      if len(sys.argv) != 2:
          print(f"Aufruf: python3 {sys.argv[0]} <riscvtest.mem>")
          sys.exit(1)
      rv_load(sys.argv[1])

