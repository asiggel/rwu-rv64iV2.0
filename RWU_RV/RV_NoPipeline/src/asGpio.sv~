`timescale 1ns/1ps

import as_pack::*;

module as_gpio ( input  logic                       rst_i,
                 input  logic                       clk_i,
                 input  logic [gpio_addr_width-1:0] addr_i,    // from BPI/WB-Bus
                 input  logic [reg_width-1:0]       data_i,    // from BPI/WB-Bus
                 output logic [reg_width-1:0]       data_o,    // to BPI/WB-Bus
                 output logic [nr_gpios-1:0]        irq_o,     // to BPI-SRB
                 input  logic                       en_i,
                 inout  tri   [nr_gpios-1:0]        gpio_io,   // to Pin
                 output logic                       cs_o       // to Pin   
                );
  
  parameter int dire_reg_addr_c = gpio_direction_reg_addr_offs_c;
  parameter int	gpio_reg_addr_c = gpio_data_reg_addr_offs_c;

  logic [reg_width-1:0] direction;      // register: address=08
  logic [reg_width-1:0] gpio_out_s;     // register: address=12
  logic [reg_width-1:0] gpio_in_s;

  logic [nr_gpios-1:0][1:0] shift_reg_s;
  logic	[nr_gpios-1:0]      irq_pulse_s;
  logic			    irq_pulse07_s;
  logic [reg_width-1:0]     irq_reg_s;      // register: raw interrupt
  
  
  //--------------------------------------------
  // register-64 bit: direction; address = 8
  //--------------------------------------------
  always_ff @(posedge clk_i, posedge rst_i)
  begin
    if(rst_i == 1)
      direction <= 0;
    else
      if ( (en_i == 1) & (addr_i == dire_reg_addr_c) )
        direction <= data_i;
  end

  //--------------------------------------------
  // resolution function: direction = 0: output
  //                      direction = 1: input
  //--------------------------------------------
  genvar j;
  generate
    for (j=0; j < nr_gpios; j++)
      assign gpio_io[j]  =  (~direction[j]) ? gpio_out_s[j] : 1'bz; // tristate driver in output direction
  endgenerate

  genvar m;
  generate
    for (m=0; m < nr_gpios; m++)
      assign gpio_in_s[m] = (direction[m])  ? gpio_io[m]    : 1'b0; // tristate driver in input direction
  endgenerate

  genvar n;
  generate
    for (n=nr_gpios; n < reg_width; n++)
      assign gpio_in_s[n] = 1'b0; // rest of the vector
  endgenerate
  
  //--------------------------------------------
  // register-64 bit: gpio; address = C
  //--------------------------------------------
  // ... first 8 bit of the register
  genvar i;
  generate
    for (i=0; i < nr_gpios; i++)
    begin
      always_ff @(posedge clk_i, posedge rst_i)
      begin
        if(rst_i == 1)
          gpio_out_s[i] <= 0;
        else
          if (direction[i])
            gpio_out_s[i] <= gpio_in_s[i];  // input; pad to register (gpio_io[i])
          else
            if ( (en_i == 1) & (addr_i == gpio_reg_addr_c) )
              gpio_out_s[i] <= data_i[i]; // output; bus to register
      end // always_ff @ (posedge clk_i, posedge rst_i)
    end // for (i=0; i < 7; i++)
  endgenerate

  // ... remaining bits of the register
  always_ff @(posedge clk_i, posedge rst_i)
  begin
    if(rst_i == 1)
      gpio_out_s[reg_width-1:nr_gpios] <= 0;
    else
      if ( (en_i == 1) & (addr_i == gpio_reg_addr_c) )
	gpio_out_s[reg_width-1:nr_gpios] <= data_i[reg_width-1:nr_gpios];
  end
  
  //--------------------------------------------
  // register cs_s
  //--------------------------------------------
  always_ff @(posedge clk_i, posedge rst_i)
  begin
    if(rst_i == 1)
      cs_o          <= 0;
    else
      if ( (en_i == 1) & (addr_i == gpio_reg_addr_c) )
        cs_o        <= en_i;
      else
        cs_o        <= 0;
  end // always_ff @ (posedge clk_i, posedge rst_i)

  //--------------------------------------------
  // data to bus reg_width
  //--------------------------------------------
  always_comb
  begin
    case(addr_i)
      dire_reg_addr_c       : data_o = direction;
      gpio_reg_addr_c       : data_o = gpio_out_s;
      default               : data_o = 0;
    endcase
  end

  //--------------------------------------------
  // IRQ generation: signal change on input
  //--------------------------------------------
  // Shift register
  genvar k;
  generate
    for (k=0; k < nr_gpios; k++)
    begin
      always_ff @(posedge clk_i, posedge rst_i)
      begin
        if(rst_i == 1)
        begin
          shift_reg_s[k][0] <= 0;
          shift_reg_s[k][1] <= 0;
        end
        else
	begin
	  if (direction[k] == 1)
	  begin
            shift_reg_s[k][0] <= gpio_in_s[k]; // gpio_io[k]
            shift_reg_s[k][1] <= shift_reg_s[k][0];
	  end
	end
      end
    end // for (k=0; k < nr_gpios; k++)
  endgenerate

  // Edge detector
  genvar l;
  generate
    for (l=0; l < nr_gpios; l++)
      assign irq_pulse_s[l] =  shift_reg_s[l][0] ^ shift_reg_s[l][1];
  endgenerate

  // To IRQ Register
  assign irq_o = irq_pulse_s;
  
endmodule : as_gpio

